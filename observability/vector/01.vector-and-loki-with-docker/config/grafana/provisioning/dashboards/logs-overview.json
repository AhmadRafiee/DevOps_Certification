{
  "title": "Logs Overview",
  "uid": "logs-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "All Logs",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 12 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{service=~\".+\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "enableLogDetails": true,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Log Rate by Service",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (service) (rate({service=~\".+\"}[2m]))",
          "queryType": "range",
          "refId": "A",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Log Rate by Level",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (level) (rate({level=~\".+\"}[2m]))",
          "queryType": "range",
          "refId": "A",
          "legendFormat": "{{level}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Errors Only",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{level=~\"error|critical|fatal\"}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
